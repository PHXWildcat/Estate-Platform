    "@estate/authz": "workspace:*",
    "@estate/contracts": "workspace:*",
    "@estate/crypto": "workspace:*",
    "@estate/db": "workspace:*",
    "@estate/kms-aws": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "kafkajs": "catalog:",
    "pg": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@estate/config": "workspace:*",
    "@nestjs/testing": "catalog:",
