{
  "name": "@estate/service-documents",
  "version": "0.0.1",
  "private": true,
  "description": "Document service: state-specific template matrix (versioned like code, attorney sign-off gated), generation pipeline, execution-status tracking, version history. Owns the documents cluster (docs/01 §2.4, docs/02 §4). Content is stored as per-document-DEK envelope ciphertext in the object store; the DB holds metadata and content hashes only.",
  "main": "dist/main.js",
  "scripts": {
